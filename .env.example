# Database
# TCP URL — used by the app at runtime (pg adapter)
DATABASE_URL="postgres://postgres:postgres@localhost:5432/community_matcher?sslmode=disable"

# HTTP URL — used by Prisma CLI for migrations (only needed if using `npx prisma dev`)
# Run `npx prisma dev` in a separate terminal, then paste the prisma+postgres:// URL it prints here
# If using your own Postgres, leave this blank — it falls back to DATABASE_URL
MIGRATE_DATABASE_URL=""

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="change-me"

# Google OAuth (optional — email/password works without these)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# UploadThing (required for photo uploads)
UPLOADTHING_TOKEN=""

# Resend (required for email verification)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="SamuDate <noreply@samudate.com>"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
